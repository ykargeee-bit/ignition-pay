# Application
NODE_ENV=development
PORT=3000
ENABLE_SWAGGER=true

# Database (Prisma / PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stellaraid?schema=public"

# Database backups
# DATABASE_BACKUP_DIR stores local pg_dump files. Keep it out of git.
DATABASE_BACKUP_DIR="./backups/database"
# DATABASE_BACKUP_RETENTION_DAYS removes local backup files older than this.
DATABASE_BACKUP_RETENTION_DAYS=14
# Optional: copy every new backup into a second mounted/archive directory.
DATABASE_BACKUP_ARCHIVE_DIR=

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=change-me-in-production

# Admin wallet allowlist (comma-separated Stellar public keys)
# On auth, any wallet in this list will receive role=ADMIN
ADMIN_WALLETS=

# Refresh token secret (use a long random string, separate from JWT_SECRET)
REFRESH_TOKEN_SECRET=change-me-refresh-secret

# Login lockout configuration
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# Session configuration
# Access token lifetime in seconds (default: 15 min)
SESSION_ACCESS_TTL_SECONDS=900
# Session / refresh token lifetime in seconds (default: 7 days)
SESSION_TTL_SECONDS=604800
# Password hashing
PASSWORD_BCRYPT_ROUNDS=12

# Sentry (crash reporting)
SENTRY_DSN=