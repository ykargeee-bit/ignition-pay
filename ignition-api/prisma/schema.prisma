// Prisma schema for StellarAid API
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS: Define domain-specific enumerations
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  DONOR
  CREATOR
  ADMIN
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum DonationStatus {
  PENDING
  CONFIRMED
  REFUNDED
  FAILED
}

enum MilestoneStatus {
  PENDING
  ACTIVE
  COMPLETED
  FAILED
}

enum NotificationType {
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  DONATION_RECEIVED
  MILESTONE_REACHED
  CAMPAIGN_COMPLETED
  DISPUTE_FILED
  DISPUTE_RESOLVED
}

enum DisputeStatus {
  OPENED
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum AuditActionType {
  USER_CREATED
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  DONATION_MADE
  MILESTONE_COMPLETED
  DISPUTE_FILED
  ADMIN_ACTION
}

enum WalletNetwork {
  STELLAR
  ETHEREUM
  BITCOIN
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ---------------------------------------------------------------------------
// MODELS: Define all database models with relationships and constraints
// ---------------------------------------------------------------------------

/// User model representing donors, creators, and administrators
model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  email         String?   @unique
  displayName   String?
  name          String?
  phone         String?
  preferences   Json?
  role          UserRole  @default(USER)
  kycStatus     KycStatus @default(UNVERIFIED)
  bio           String?
  avatarUrl     String?
  socialLinks   Json?
  passwordHash  String?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  campaigns     Campaign[]     @relation("CampaignCreator")
  donations     Donation[]
  updates       Update[]       @relation("UpdateCreator")
  notifications Notification[]
  disputes      Dispute[]      @relation("DisputeFiler")
  newsLetterSub Newsletter?
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
  wallets       Wallet[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([kycStatus])
  @@map("users")
}

/// ApiKey model for third-party integrations
model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  name      String
  keyHash   String   @unique
  prefix    String
  isActive  Boolean  @default(true)
  scope     String   @default("read")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

/// Campaign model representing fundraising campaigns
model Campaign {
  id           String         @id @default(uuid())
  title        String
  description  String
  goalAmount   Decimal        @db.Decimal(20, 7)
  raisedAmount Decimal        @default(0) @db.Decimal(20, 7)
  status       CampaignStatus @default(DRAFT)
  creatorId    String
  startDate    DateTime?
  endDate      DateTime?
  imageUrl     String?
  category     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  creator    User        @relation("CampaignCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  donations  Donation[]
  milestones Milestone[]
  updates    Update[]
  disputes   Dispute[]

  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@index([category])
  @@map("campaigns")
}

/// Donation model representing individual donations to campaigns
model Donation {
  id          String         @id @default(uuid())
  amount      Decimal        @db.Decimal(20, 7)
  assetCode   String         @default("XLM")
  txHash      String?        @unique
  status      DonationStatus @default(PENDING)
  donorId     String
  campaignId  String
  donatedAt   DateTime       @default(now())
  confirmedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  donor    User      @relation(fields: [donorId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  disputes Dispute[]

  @@unique([donorId, campaignId, txHash])
  @@index([donorId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@map("donations")
}

/// Milestone model representing campaign milestones
model Milestone {
  id           String          @id @default(uuid())
  campaignId   String
  title        String
  description  String?
  targetAmount Decimal         @db.Decimal(20, 7)
  status       MilestoneStatus @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@map("milestones")
}

/// Update model representing campaign progress updates
model Update {
  id         String   @id @default(uuid())
  campaignId String
  creatorId  String
  title      String
  content    String
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  User     @relation("UpdateCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([creatorId])
  @@index([createdAt])
  @@map("updates")
}

/// Notification model for user notifications
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  relatedId String? // ID of related resource (campaign, donation, etc.)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

/// Dispute model for handling donation disputes
model Dispute {
  id          String        @id @default(uuid())
  donationId  String
  filerId     String
  campaignId  String
  reason      String
  description String
  status      DisputeStatus @default(OPENED)
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  filer    User     @relation("DisputeFiler", fields: [filerId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([donationId])
  @@index([filerId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@map("disputes")
}

/// Newsletter model for newsletter subscriptions
model Newsletter {
  id             String    @id @default(uuid())
  userId         String    @unique
  email          String    @unique
  isSubscribed   Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([isSubscribed])
  @@map("newsletters")
}

/// AuditLog model for tracking system actions
model AuditLog {
  id           String          @id @default(uuid())
  userId       String?
  action       AuditActionType
  resourceType String
  resourceId   String
  details      String? // JSON stringified details
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime        @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Wallet model representing a user's custodial wallet with deposit address and limits
model Wallet {
  id              String        @id @default(uuid())
  userId          String
  network         WalletNetwork @default(STELLAR)
  depositAddress  String        @unique
  label           String?
  dailyLimit      Decimal       @default(1000) @db.Decimal(20, 7)
  monthlyLimit    Decimal       @default(10000) @db.Decimal(20, 7)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([depositAddress])
  @@index([network])
  @@map("wallets")
}
